---
import { getCollection } from 'astro:content';
import { localeLinks, type Lang } from '../lib/paths';

interface Props { lang: Lang; slug: string }
const { lang, slug } = Astro.props;

const ids = (await getCollection('pages')).map((e) => e.id);
const links = localeLinks(ids, lang, slug);
---
{links.length > 1 && (
  <div class="lang-switch">
    {links.map((l) =>
      l.current ? (
        <span class="current" aria-current="true">{l.lang.toUpperCase()}</span>
      ) : (
        <a href={l.href} hreflang={l.lang}>{l.lang.toUpperCase()}</a>
      ),
    )}
  </div>
)}
