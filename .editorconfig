# EditorConfig — https://editorconfig.org
# Line endings are LF everywhere; UTF-8; 2-space indent.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: keep trailing spaces — two of them are a hard line break.
[*.md]
trim_trailing_whitespace = false

# Astro components and the web sources.
[*.{astro,js,mjs,ts,css,json}]
indent_size = 2

# GitHub Actions / config YAML.
[*.{yml,yaml}]
indent_size = 2

# CNAME holds exactly the apex domain — no trailing blank line.
[CNAME]
insert_final_newline = false

# Binary assets — EditorConfig rules don't apply.
[*.{ico,png,jpg,jpeg,gif,webp,woff,woff2}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
